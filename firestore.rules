rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email in [
        // Add your actual admin emails here:
        'admin@example.com'
      ];
    }

    function isSpecial() {
      return isSignedIn() && request.auth.token.email in [
        // Add your special user emails here:
        'stuti@example.com'
      ];
    }

    function isAdminOrSpecial() {
      return isAdmin() || isSpecial();
    }

    match /wishes/{wishId} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if isAdminOrSpecial();
    }

    match /gallery/{galleryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /privateMoments/{momentId} {
      allow read, create, update, delete: if isAdminOrSpecial();
    }

    match /specialDays/{specialDayId} {
      allow read, create, update, delete: if isAdminOrSpecial();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
